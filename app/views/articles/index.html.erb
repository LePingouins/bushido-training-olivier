
<style>
  body {
    font-family: 'Segoe UI', Arial, sans-serif;
    background: #f5f6fa;
    margin: 0;
    padding: 0;
  }
  .articles-list {
    max-width: 800px;
    margin: 40px auto 0 auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .article-card {
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.07);
    padding: 24px 32px 18px 32px;
    display: flex;
    flex-direction: column;
    position: relative;
    border: 2px solid transparent;
    transition: box-shadow 0.2s, border 0.2s;
  }
  .article-card.premium {
    background: #fffbe6;
    border-color: #ffd700;
  }
  .article-title {
    font-size: 1.3em;
    font-weight: bold;
    color: #222;
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .premium-label {
    background: #ffd700;
    color: #7c6500;
    font-size: 0.95em;
    font-weight: 600;
    border-radius: 6px;
    padding: 2px 10px;
    margin-left: 6px;
  }
  .article-body {
    color: #444;
    margin-bottom: 12px;
  }
  .article-actions {
    margin-top: 10px;
    text-align: right;
  }
  .article-actions a {
    margin-left: 12px;
    color: #007bff;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s;
  }
  .article-actions a:hover {
    color: #0056b3;
  }
  .new-article-btn {
    display: block;
    width: fit-content;
    margin: 32px auto 0 auto;
    background: #007bff;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 10px 24px;
    font-size: 1.1em;
    font-weight: 500;
    text-decoration: none;
    box-shadow: 0 1px 4px rgba(0,0,0,0.07);
    transition: background 0.2s;
  }
  .new-article-btn:hover {
    background: #0056b3;
  }
</style>

<div class="articles-list">
  <% @articles.each do |article| %>
    <div class="article-card<%= ' premium' if article.premium_content %>">
      <div class="article-title">
        <%= article.title %>
        <% if article.premium_content %>
          <span class="premium-label">Premium Member Only</span>
        <% end %>
      </div>
      <div class="article-body"><%= article.body %></div>
      <div class="article-actions">
        <%= link_to 'Show', article %>
        <%= link_to 'Edit', edit_article_path(article) %>
      </div>
    </div>
  <% end %>
</div>

<%= link_to 'New Article', new_article_path, class: 'new-article-btn' %>
